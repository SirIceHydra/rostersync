{
  "$schema": "rostersync-design-system-v1",
  "brand": {
    "name": "RosterSync",
    "wordmark": "rostersync.",
    "tagline": "Healthcare scheduling that's fair, fast, and transparent",
    "voice": "Calm, confident, human. Clear over clever. No jargon, no hype.",
    "personality": ["trustworthy", "efficient", "warm", "modern"]
  },
  "color": {
    "brand": {
      "purple": { "value": "#5D41B9", "role": "primary, brand, links, primary buttons", "onColor": "#FFFFFF" },
      "purple-700": { "value": "#4A32A0", "role": "primary hover/pressed" },
      "purple-500": { "value": "#7B62D1", "role": "primary subtle" },
      "purple-100": { "value": "#EAE3FA", "role": "primary tinted backgrounds, badges, focus rings" },
      "purple-50":  { "value": "#F5F1FE", "role": "primary super-light surfaces" },
      "orange":     { "value": "#FF912A", "role": "secondary brand accent, highlights, dot punctuation, alert nudges", "onColor": "#1B1230" },
      "orange-600": { "value": "#E87A14", "role": "orange hover" },
      "orange-100": { "value": "#FFE7CF", "role": "orange tinted backgrounds" },
      "orange-50":  { "value": "#FFF4E6", "role": "orange super-light surfaces" }
    },
    "neutral": {
      "ink":      { "value": "#1B1230", "role": "primary text, dark surfaces" },
      "slate-900":{ "value": "#2A2140" },
      "slate-700":{ "value": "#4A4360", "role": "secondary text" },
      "slate-500":{ "value": "#6B6478", "role": "muted text, captions" },
      "slate-300":{ "value": "#C9C3D6", "role": "borders strong" },
      "slate-200":{ "value": "#E8E2D8", "role": "borders default, dividers" },
      "slate-100":{ "value": "#F2EEE8", "role": "subtle surfaces, hover" },
      "paper":    { "value": "#FAF8F5", "role": "app background — warm off-white" },
      "white":    { "value": "#FFFFFF", "role": "cards, sheets" }
    },
    "semantic": {
      "success":         { "value": "#1F9D67", "role": "confirmed, published, healthy" },
      "success-bg":      { "value": "#E1F4EB" },
      "warning":         { "value": "#D98B12", "role": "needs attention, pending" },
      "warning-bg":      { "value": "#FCF1DD" },
      "danger":          { "value": "#D6443B", "role": "errors, conflicts, destructive" },
      "danger-bg":       { "value": "#FBE3E1" },
      "info":            { "value": "#2C7AB8", "role": "informational" },
      "info-bg":         { "value": "#E1EEF8" }
    }
  },
  "typography": {
    "fontFamilies": {
      "display": "'Bricolage Grotesque', 'Nunito', system-ui, sans-serif",
      "body": "'Inter', system-ui, -apple-system, Segoe UI, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace"
    },
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap",
    "scale": {
      "display-xl": { "size": 64, "lineHeight": 1.05, "weight": 800, "letterSpacing": "-0.03em", "family": "display", "use": "marketing hero, splash" },
      "display-lg": { "size": 48, "lineHeight": 1.08, "weight": 800, "letterSpacing": "-0.025em", "family": "display", "use": "page heroes" },
      "h1":         { "size": 36, "lineHeight": 1.15, "weight": 700, "letterSpacing": "-0.02em", "family": "display", "use": "page titles" },
      "h2":         { "size": 28, "lineHeight": 1.2,  "weight": 700, "letterSpacing": "-0.015em", "family": "display", "use": "section headers" },
      "h3":         { "size": 22, "lineHeight": 1.25, "weight": 700, "letterSpacing": "-0.01em", "family": "display", "use": "card titles" },
      "h4":         { "size": 18, "lineHeight": 1.3,  "weight": 600, "family": "display", "use": "subheaders" },
      "body-lg":    { "size": 17, "lineHeight": 1.55, "weight": 400, "family": "body", "use": "lead paragraphs" },
      "body":       { "size": 15, "lineHeight": 1.55, "weight": 400, "family": "body", "use": "default body, table rows, form inputs" },
      "body-sm":    { "size": 13, "lineHeight": 1.5,  "weight": 400, "family": "body", "use": "secondary text" },
      "label":      { "size": 13, "lineHeight": 1.4,  "weight": 500, "family": "body", "use": "form labels, button text" },
      "caption":    { "size": 12, "lineHeight": 1.4,  "weight": 400, "family": "body", "use": "captions, meta text" },
      "overline":   { "size": 11, "lineHeight": 1.3,  "weight": 600, "letterSpacing": "0.12em", "family": "body", "use": "section eyebrows", "transform": "uppercase" },
      "mono":       { "size": 13, "lineHeight": 1.5,  "weight": 400, "family": "mono", "use": "ids, codes, timestamps" }
    },
    "rules": [
      "Use display family (Bricolage Grotesque) ONLY for headings, the wordmark, and big numbers/stats.",
      "Use body family (Inter) for everything else — body copy, buttons, form labels, table cells.",
      "Never set body type below 13px. 15px is the floor for primary content.",
      "Tighten letter-spacing on large display sizes; loosen on small overline/caption.",
      "Use text-wrap: pretty on paragraphs and balance on headings."
    ]
  },
  "spacing": {
    "unit": 4,
    "scale": {
      "0": 0, "0.5": 2, "1": 4, "1.5": 6, "2": 8, "3": 12, "4": 16, "5": 20,
      "6": 24, "8": 32, "10": 40, "12": 48, "16": 64, "20": 80, "24": 96, "32": 128
    },
    "rules": [
      "Stick to the 4-px grid. No 7px, no 13px paddings.",
      "Use gap (flex/grid) over per-element margin where possible.",
      "Default card padding: 24px desktop, 16px mobile.",
      "Default vertical rhythm between sections: 48–64px."
    ]
  },
  "radius": {
    "none": 0, "sm": 6, "md": 10, "lg": 14, "xl": 18, "2xl": 24, "pill": 9999,
    "rules": [
      "Buttons: pill (full-rounded) for primary CTAs, md (10px) for secondary/icon buttons.",
      "Cards: lg (14px) default, xl (18px) for elevated/marketing cards.",
      "Inputs: md (10px).",
      "Modals/sheets: 2xl (24px) top corners on bottom-sheets, xl (18px) on dialogs."
    ]
  },
  "shadow": {
    "none": "none",
    "xs": "0 1px 2px rgba(27,18,48,0.05)",
    "sm": "0 2px 6px rgba(27,18,48,0.06), 0 1px 2px rgba(27,18,48,0.04)",
    "md": "0 6px 16px rgba(27,18,48,0.08), 0 2px 4px rgba(27,18,48,0.04)",
    "lg": "0 16px 40px rgba(27,18,48,0.10), 0 4px 8px rgba(27,18,48,0.05)",
    "xl": "0 32px 64px rgba(27,18,48,0.14)",
    "focus-purple": "0 0 0 3px rgba(93,65,185,0.30)",
    "focus-orange": "0 0 0 3px rgba(255,145,42,0.35)",
    "rules": [
      "Use shadows sparingly. Default cards rely on a 1px border in slate-200 — no shadow.",
      "Add sm shadow on hover for clickable cards. Use md only for floating elements (popovers, dropdowns).",
      "Reserve lg/xl for modals and toasts."
    ]
  },
  "borders": {
    "width": { "default": 1, "strong": 2, "focus": 3 },
    "color": { "default": "slate-200", "strong": "slate-300", "focus": "purple" }
  },
  "motion": {
    "easing": {
      "standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "accelerate": "cubic-bezier(0.4, 0, 1, 1)"
    },
    "duration": { "instant": 80, "fast": 150, "base": 220, "slow": 360, "deliberate": 500 },
    "rules": [
      "Hover/press: 150ms standard. State changes: 220ms standard.",
      "Page transitions, expanding sections: 360ms decelerate.",
      "Avoid bouncy/elastic easings except on the sync-spinner where rotation reinforces brand."
    ]
  },
  "iconography": {
    "library": "Lucide (lucide.dev) — line, 1.75px stroke, rounded caps/joins",
    "size": { "sm": 16, "md": 20, "lg": 24, "xl": 32 },
    "color": "Match adjacent text color. Use orange only for accent indicators (notifications, alerts).",
    "customMarks": [
      "RosterSync sync-circle (used in logo) is reserved for branding contexts only — do not reuse as a generic refresh icon."
    ]
  },
  "imagery": {
    "photography": "Real clinicians, candid, natural light. Avoid stock-medical clichés (stethoscope-on-clipboard, blue-tinted hospital corridors).",
    "illustration": "Geometric, flat, 2-color (purple + orange) on paper background. Minimal line work, generous negative space.",
    "placeholders": "Use 1px diagonal-stripe SVG patterns in slate-200 with monospace caption inside; never auto-generate fake portraits.",
    "ratios": ["1:1 avatars", "16:9 hero", "4:3 card thumbnails", "3:2 marketing"]
  },
  "components": {
    "button": {
      "shared": {
        "fontFamily": "body",
        "fontWeight": 500,
        "fontSize": 15,
        "lineHeight": 1.0,
        "borderRadius": "pill",
        "padding": "10px 20px",
        "iconGap": 8,
        "transition": "all 150ms standard",
        "focusRing": "focus-purple",
        "minHeight": 44
      },
      "variants": {
        "primary":   { "bg": "purple", "fg": "white", "hover.bg": "purple-700", "active.bg": "purple-700", "disabled.opacity": 0.5 },
        "secondary": { "bg": "white", "fg": "ink", "border": "1px solid slate-200", "hover.bg": "slate-100", "hover.border": "slate-300" },
        "ghost":     { "bg": "transparent", "fg": "purple", "hover.bg": "purple-50" },
        "danger":    { "bg": "danger", "fg": "white", "hover.bg": "#B83730" },
        "accent":    { "bg": "orange", "fg": "ink", "hover.bg": "orange-600" }
      },
      "sizes": {
        "sm": { "padding": "6px 14px", "fontSize": 13, "minHeight": 32, "iconSize": 16 },
        "md": { "padding": "10px 20px", "fontSize": 15, "minHeight": 44, "iconSize": 20 },
        "lg": { "padding": "14px 28px", "fontSize": 17, "minHeight": 52, "iconSize": 20 }
      },
      "iconButton": { "shape": "square with md radius", "size.md": 40, "size.sm": 32 }
    },
    "input": {
      "fontFamily": "body",
      "fontSize": 15,
      "padding": "10px 14px",
      "minHeight": 44,
      "borderRadius": "md",
      "border": "1px solid slate-200",
      "bg": "white",
      "fg": "ink",
      "placeholderColor": "slate-500",
      "hover.border": "slate-300",
      "focus.border": "purple",
      "focus.ring": "focus-purple",
      "error.border": "danger",
      "error.ring": "0 0 0 3px rgba(214,68,59,0.25)",
      "label": "label scale, slate-700, mb 6px",
      "helperText": "caption scale, slate-500, mt 6px",
      "errorText": "caption scale, danger, mt 6px"
    },
    "select": "Same as input + chevron-down icon (slate-500) at right, 10px gap",
    "checkbox": {
      "size": 18, "borderRadius": "sm", "border": "1.5px solid slate-300",
      "checked.bg": "purple", "checked.border": "purple", "icon": "white check, 12px",
      "focus.ring": "focus-purple"
    },
    "radio": "Like checkbox but pill radius, inner dot 8px purple",
    "switch": {
      "track.size": "36x22", "track.bg.off": "slate-300", "track.bg.on": "purple",
      "thumb.size": 18, "thumb.bg": "white", "thumb.shadow": "sm",
      "transition": "220ms standard"
    },
    "card": {
      "bg": "white",
      "border": "1px solid slate-200",
      "borderRadius": "lg",
      "padding": 24,
      "shadow": "none",
      "hover.shadow": "sm (only if interactive)",
      "header": "h3 + optional caption, mb 16px",
      "footer": "mt 20px, pt 16px, border-top 1px slate-200"
    },
    "pill": {
      "fontFamily": "body",
      "fontSize": 12,
      "fontWeight": 600,
      "letterSpacing": "0.04em",
      "textTransform": "uppercase",
      "padding": "4px 10px",
      "borderRadius": "pill",
      "minHeight": 22,
      "variants": {
        "neutral":  { "bg": "slate-100", "fg": "slate-700" },
        "brand":    { "bg": "purple-100", "fg": "purple" },
        "accent":   { "bg": "orange-100", "fg": "#9C4F0E" },
        "success":  { "bg": "success-bg", "fg": "success" },
        "warning":  { "bg": "warning-bg", "fg": "warning" },
        "danger":   { "bg": "danger-bg", "fg": "danger" },
        "info":     { "bg": "info-bg", "fg": "info" }
      }
    },
    "tag": "Like pill but lowercase, 13px, weight 500, slate-100/slate-700",
    "avatar": {
      "sizes": { "xs": 24, "sm": 32, "md": 40, "lg": 56, "xl": 80 },
      "borderRadius": "pill",
      "fallback.bg": "purple-100",
      "fallback.fg": "purple",
      "fallback.fontWeight": 600,
      "ring.online": "2px solid success on white background",
      "stack.overlap": "-8px"
    },
    "table": {
      "header": "overline scale, slate-500, padding 12px 16px, border-bottom 1px slate-200",
      "row": "body scale, padding 14px 16px, border-bottom 1px slate-200",
      "row.hover.bg": "slate-100",
      "row.selected.bg": "purple-50",
      "zebra": "off — keep clean lines"
    },
    "navbar": {
      "height": 64,
      "bg": "white",
      "border": "1px solid slate-200 (bottom only)",
      "logo.height": 28,
      "links": "label scale, slate-700, hover ink",
      "active.indicator": "2px purple bottom-border or pill background purple-50"
    },
    "sidebar": {
      "width": 248,
      "bg": "paper",
      "border": "1px solid slate-200 (right only)",
      "section.label": "overline, slate-500, padding 8px 16px",
      "item": "label scale, padding 10px 14px, radius md, gap 12px (icon + text)",
      "item.hover.bg": "slate-100",
      "item.active.bg": "purple-100",
      "item.active.fg": "purple",
      "item.active.fontWeight": 600
    },
    "modal": {
      "scrim": "rgba(27,18,48,0.45) blur(4px)",
      "container.bg": "white",
      "container.borderRadius": "xl",
      "container.shadow": "xl",
      "container.padding": 32,
      "container.maxWidth": 520,
      "title": "h2",
      "closeButton": "iconButton ghost top-right"
    },
    "toast": {
      "bg": "ink", "fg": "white", "borderRadius": "md", "padding": "12px 16px",
      "shadow": "lg", "fontSize": 14,
      "variant.success.accent": "2px left border success",
      "variant.error.accent": "2px left border danger",
      "duration": 4500
    },
    "tabs": {
      "list.gap": 4,
      "tab.padding": "10px 16px",
      "tab.fg": "slate-700",
      "tab.fontWeight": 500,
      "active.bg": "white",
      "active.fg": "ink",
      "active.shadow": "xs",
      "container.bg": "slate-100",
      "container.borderRadius": "lg",
      "container.padding": 4
    },
    "alert": {
      "padding": 16,
      "borderRadius": "lg",
      "border": "1px solid (variant tint)",
      "variants": {
        "info":    { "bg": "info-bg",    "border": "info",    "icon": "info" },
        "success": { "bg": "success-bg", "border": "success", "icon": "check-circle" },
        "warning": { "bg": "warning-bg", "border": "warning", "icon": "alert-triangle" },
        "danger":  { "bg": "danger-bg",  "border": "danger",  "icon": "alert-circle" }
      }
    },
    "tooltip": { "bg": "ink", "fg": "white", "fontSize": 12, "padding": "6px 10px", "radius": "sm", "shadow": "md", "delay": 400 },
    "progress": { "track.bg": "slate-200", "fill.bg": "purple", "height": 6, "radius": "pill" },
    "skeleton": { "bg": "slate-100", "shimmer": "linear-gradient slate-200", "radius": "match parent" },
    "divider": { "color": "slate-200", "thickness": 1, "spacing": 24 }
  },
  "layout": {
    "breakpoints": { "sm": 640, "md": 768, "lg": 1024, "xl": 1280, "2xl": 1536 },
    "container.maxWidth": 1240,
    "container.padding": { "mobile": 20, "desktop": 40 },
    "page.background": "paper"
  },
  "accessibility": {
    "minContrast": { "text": 4.5, "largeText": 3.0, "uiComponent": 3.0 },
    "focusVisible": "Always show purple focus ring on keyboard focus. Never remove without replacement.",
    "minTouchTarget": 44,
    "motion": "Respect prefers-reduced-motion: disable rotation/parallax, keep opacity fades."
  },
  "doNots": [
    "Don't use the orange-purple as a gradient — keep them adjacent, not blended.",
    "Don't reuse the sync-circle mark as a generic UI icon.",
    "Don't combine more than 2 background tints on a single screen.",
    "Don't use pure black (#000) or pure white (#FFF) for body text — use ink and paper.",
    "Don't apply shadow + border + tint stacked on the same element.",
    "Don't use Bricolage Grotesque below 18px — switch to Inter."
  ]
}
