# ── Quick URL map (browser / Postman always hits the gateway) ─────────────────
#   Gateway (use this from the frontend):     http://localhost:4000
#   Auth:      http://localhost:4001   Roster: http://localhost:4002   Request: http://localhost:4003
#   User:      http://localhost:4004   Analytics: http://localhost:4005
# Do not point VITE_API_URL at 4001–4005 — those apps only expose partial routes; /api/rosters/archive lives behind the gateway.

# ── Database ──────────────────────────────────────────────────────────────────
# Full Postgres connection string — provided by your hosting platform (Railway, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/rostersync

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_character_random_string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API.
# Leave unset in dev to allow common localhost ports (3000–3005, 5173…).
# Production example:
# CORS_ORIGIN=https://yourdomain.com
# Dev with explicit ports only:
# CORS_ORIGIN=http://localhost:3000,http://localhost:3003

# ── Service ports (defaults shown — only change if there are port conflicts) ──
GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
ROSTER_SERVICE_PORT=4002
REQUEST_SERVICE_PORT=4003
USER_SERVICE_PORT=4004
ANALYTICS_SERVICE_PORT=4005

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
