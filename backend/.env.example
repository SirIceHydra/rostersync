# ── Database ──────────────────────────────────────────────────────────────────
# Full Postgres connection string — provided by your hosting platform (Railway, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/rostersync

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_character_random_string

# ── CORS ──────────────────────────────────────────────────────────────────────
# The URL of your deployed frontend (no trailing slash)
CORS_ORIGIN=https://yourdomain.com

# ── Service ports (defaults shown — only change if there are port conflicts) ──
GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
ROSTER_SERVICE_PORT=4002
REQUEST_SERVICE_PORT=4003
USER_SERVICE_PORT=4004
ANALYTICS_SERVICE_PORT=4005

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
