# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Optional. If unset or empty, `npm run dev` proxies /api → gateway (see vite.config.ts).
# Set explicitly only if the UI must call a remote gateway or bypass the proxy.
# Always use the GATEWAY (4000), never a single microservice (4001–4005).
# VITE_API_URL=http://localhost:4000
#
# Where Vite sends proxied /api traffic when VITE_API_URL is empty (local dev):
# VITE_GATEWAY_PROXY_TARGET=http://127.0.0.1:4000

# ── Docker Compose secrets ────────────────────────────────────────────────────
# These are only needed when running docker-compose locally or in CI
POSTGRES_PASSWORD=replace_with_strong_password
JWT_SECRET=replace_with_a_64_character_random_string
CORS_ORIGIN=http://localhost
